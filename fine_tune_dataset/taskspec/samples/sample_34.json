{
    "app_name": "Digital Library App",
    "app_type": "web_app",
    "description": "A digital library application for logging in, searching digital resources, bookmarking books, and downloading available materials.",
    "target_users": [
        "students",
        "faculty"
    ],
    "frontend": {
        "pages": [
            {
                "name": "Login",
                "route": "/login",
                "components": [
                    "Navbar",
                    "LoginForm"
                ]
            },
            {
                "name": "Library",
                "route": "/",
                "components": [
                    "Navbar",
                    "SearchBar",
                    "ResourceGrid",
                    "CategoryFilter"
                ]
            },
            {
                "name": "Bookmarks",
                "route": "/bookmarks",
                "components": [
                    "Navbar",
                    "BookmarkList",
                    "RemoveBookmarkButton"
                ]
            },
            {
                "name": "Downloads",
                "route": "/downloads",
                "components": [
                    "Navbar",
                    "DownloadHistoryTable",
                    "FileTypeBadge"
                ]
            }
        ],
        "shared_components": [
            "Navbar",
            "Button",
            "Card",
            "Table",
            "Badge"
        ],
        "features": [
            "login",
            "resource search",
            "bookmarks",
            "file downloads",
            "resource filtering"
        ]
    },
    "backend": {
        "endpoints": [
            {
                "method": "POST",
                "path": "/api/login",
                "purpose": "Authenticate user"
            },
            {
                "method": "GET",
                "path": "/api/resources",
                "purpose": "Fetch digital library resources"
            },
            {
                "method": "POST",
                "path": "/api/bookmarks",
                "purpose": "Add resource to bookmarks"
            },
            {
                "method": "GET",
                "path": "/api/downloads",
                "purpose": "Fetch download history"
            }
        ]
    },
    "database": {
        "tables": [
            {
                "name": "users",
                "columns": [
                    "id",
                    "name",
                    "email",
                    "password"
                ]
            },
            {
                "name": "resources",
                "columns": [
                    "id",
                    "title",
                    "author",
                    "file_type",
                    "file_url",
                    "category"
                ]
            },
            {
                "name": "bookmarks",
                "columns": [
                    "id",
                    "user_id",
                    "resource_id",
                    "created_at"
                ]
            },
            {
                "name": "downloads",
                "columns": [
                    "id",
                    "user_id",
                    "resource_id",
                    "downloaded_at"
                ]
            }
        ]
    },
    "auth_required": true
}