{
    "app_name": "StyleHub Clothing Store",
    "app_type": "web_app",
    "description": "An online clothing store where users can browse products, apply filters, manage a cart, complete checkout, and view order history.",
    "target_users": [
        "customers",
        "store_admin"
    ],
    "frontend": {
        "pages": [
            {
                "name": "Home",
                "route": "/",
                "components": [
                    "Navbar",
                    "HeroSection",
                    "FeaturedCollections",
                    "Footer"
                ]
            },
            {
                "name": "Shop",
                "route": "/shop",
                "components": [
                    "Navbar",
                    "FilterSidebar",
                    "ProductGrid",
                    "SortDropdown"
                ]
            },
            {
                "name": "Product Details",
                "route": "/product/:id",
                "components": [
                    "Navbar",
                    "ProductGallery",
                    "ProductInfo",
                    "AddToCartButton"
                ]
            },
            {
                "name": "Cart",
                "route": "/cart",
                "components": [
                    "Navbar",
                    "CartItemList",
                    "OrderSummary",
                    "CheckoutButton"
                ]
            },
            {
                "name": "Orders",
                "route": "/orders",
                "components": [
                    "Navbar",
                    "OrderHistoryTable",
                    "StatusBadge"
                ]
            }
        ],
        "shared_components": [
            "Navbar",
            "Footer",
            "Button",
            "Card",
            "Badge"
        ],
        "features": [
            "product browsing",
            "category filtering",
            "sorting",
            "cart management",
            "checkout",
            "order history"
        ]
    },
    "backend": {
        "endpoints": [
            {
                "method": "GET",
                "path": "/api/products",
                "purpose": "Fetch clothing products"
            },
            {
                "method": "GET",
                "path": "/api/products/:id",
                "purpose": "Fetch product details"
            },
            {
                "method": "POST",
                "path": "/api/cart",
                "purpose": "Add clothing item to cart"
            },
            {
                "method": "POST",
                "path": "/api/checkout",
                "purpose": "Create customer order"
            },
            {
                "method": "GET",
                "path": "/api/orders",
                "purpose": "Fetch order history"
            }
        ]
    },
    "database": {
        "tables": [
            {
                "name": "customers",
                "columns": [
                    "id",
                    "name",
                    "email",
                    "password"
                ]
            },
            {
                "name": "products",
                "columns": [
                    "id",
                    "name",
                    "category",
                    "size",
                    "price",
                    "description",
                    "image_url",
                    "stock"
                ]
            },
            {
                "name": "cart_items",
                "columns": [
                    "id",
                    "customer_id",
                    "product_id",
                    "quantity"
                ]
            },
            {
                "name": "orders",
                "columns": [
                    "id",
                    "customer_id",
                    "total_amount",
                    "status",
                    "created_at"
                ]
            }
        ]
    },
    "auth_required": true
}