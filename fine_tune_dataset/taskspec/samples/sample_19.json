{
    "app_name": "Health Consultation Platform",
    "app_type": "web_app",
    "description": "A consultation platform for patients to log in, view doctor schedules, and manage medical appointments.",
    "target_users": [
        "patients",
        "doctors",
        "clinic_admin"
    ],
    "frontend": {
        "pages": [
            {
                "name": "Home",
                "route": "/",
                "components": [
                    "Navbar",
                    "HeroSection",
                    "DoctorHighlights",
                    "Footer"
                ]
            },
            {
                "name": "Login",
                "route": "/login",
                "components": [
                    "Navbar",
                    "LoginForm"
                ]
            },
            {
                "name": "Doctor Schedule",
                "route": "/schedule",
                "components": [
                    "Navbar",
                    "ScheduleTable",
                    "DoctorFilter"
                ]
            },
            {
                "name": "Appointments",
                "route": "/appointments",
                "components": [
                    "Navbar",
                    "AppointmentManager",
                    "StatusBadge",
                    "ActionButtons"
                ]
            }
        ],
        "shared_components": [
            "Navbar",
            "Footer",
            "Button",
            "Card",
            "Badge"
        ],
        "features": [
            "patient login",
            "doctor schedule viewing",
            "appointment creation",
            "appointment cancellation",
            "appointment status updates"
        ]
    },
    "backend": {
        "endpoints": [
            {
                "method": "POST",
                "path": "/api/login",
                "purpose": "Authenticate patient login"
            },
            {
                "method": "GET",
                "path": "/api/schedule",
                "purpose": "Fetch doctor schedules"
            },
            {
                "method": "POST",
                "path": "/api/appointments",
                "purpose": "Create appointment"
            },
            {
                "method": "PUT",
                "path": "/api/appointments/:id",
                "purpose": "Update or cancel appointment"
            },
            {
                "method": "GET",
                "path": "/api/appointments",
                "purpose": "Fetch patient appointments"
            }
        ]
    },
    "database": {
        "tables": [
            {
                "name": "patients",
                "columns": [
                    "id",
                    "name",
                    "email",
                    "password",
                    "phone"
                ]
            },
            {
                "name": "doctors",
                "columns": [
                    "id",
                    "name",
                    "specialization",
                    "availability_days",
                    "availability_time"
                ]
            },
            {
                "name": "appointments",
                "columns": [
                    "id",
                    "patient_id",
                    "doctor_id",
                    "appointment_date",
                    "status",
                    "notes"
                ]
            }
        ]
    },
    "auth_required": true
}